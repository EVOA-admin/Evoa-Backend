# Application
NODE_ENV=development
PORT=3000
APP_NAME=EVOA Backend

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=evoa
DATABASE_USE_URL=false
DATABASE_SSL=false

# Keep these low in production when using Supabase/pgBouncer/session poolers.
# Good starting point for a single backend instance:
DATABASE_POOL_MAX=3
DATABASE_POOL_MIN=0
DATABASE_IDLE_TIMEOUT_MS=10000
DATABASE_CONNECTION_TIMEOUT_MS=10000
DATABASE_SLOW_QUERY_MS=1500
TYPEORM_SYNCHRONIZE=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# AI Service (OpenAI/Anthropic)
AI_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# CORS - Comma-separated list of allowed origins
# Add all frontend URLs that need to access the API
CORS_ORIGIN=http://localhost:5173,https://evoa.co.in,https://www.evoa.co.in,https://test.evoa.co.in

# Frontend URL (for redirects)
FRONTEND_URL=https://evoa.co.in
